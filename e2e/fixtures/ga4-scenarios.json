{
  "campaign_id": "yesop-brand",
  "mock_property_id": "yesop",
  "per_day_values": {
    "users": 500,
    "sessions": 750,
    "conversions": 38,
    "revenue": 2850,
    "engagement_rate": 0.62
  },
  "spend_scenarios": [
    { "type": "add", "amount": 950, "label": "Manual $950" },
    { "type": "add", "amount": 500, "label": "Add $500 more" },
    { "type": "edit", "new_amount": 800, "label": "Edit first source to $800" },
    { "type": "delete_first", "label": "Delete first spend source" }
  ],
  "kpi_scenarios": [
    { "metric": "ROAS", "target": "250", "unit": "%", "expect_band": "above", "reason": "Current ~300% > 250% target" },
    { "metric": "ROI", "target": "150", "unit": "%", "expect_band": "above", "reason": "Current ~200% > 150% target" },
    { "metric": "CPA", "target": "30", "unit": "$", "expect_band": "above", "reason": "Current ~$25 < $30 (lower-is-better = good)" },
    { "metric": "Revenue", "target": "10000", "unit": "$", "expect_band": "below", "reason": "Current ~$2,850 < $10,000 target" },
    { "metric": "Conversion Rate", "target": "3", "unit": "%", "expect_band": "above", "reason": "Current ~5.07% > 3% target" },
    { "metric": "Total Sessions", "target": "500", "unit": "count", "expect_band": "above", "reason": "Current ~750 > 500 target" },
    { "metric": "Total Users", "target": "1000", "unit": "count", "expect_band": "below", "reason": "Current ~500 < 1000 target" }
  ],
  "benchmark_scenarios": [
    { "metric": "sessions", "name": "Sessions Benchmark", "benchmark": "1000", "unit": "count" },
    { "metric": "revenue", "name": "Revenue Benchmark", "benchmark": "5000", "unit": "$" },
    { "metric": "cpa", "name": "CPA Benchmark", "benchmark": "30", "unit": "$" },
    { "metric": "roas", "name": "ROAS Benchmark", "benchmark": "200", "unit": "%" },
    { "metric": "engagementRate", "name": "Engagement Rate Benchmark", "benchmark": "80", "unit": "%" }
  ],
  "refresh_cycles": 3,
  "insights_scenarios": [
    {
      "id": "kpi_behind",
      "description": "KPI with unreachable target should trigger 'Needs Attention' insight",
      "kpi_metric": "Revenue",
      "kpi_target": "50000",
      "kpi_unit": "$",
      "expect_text": "Needs Attention",
      "expect_severity": "medium"
    },
    {
      "id": "kpi_exceeds",
      "description": "KPI with easy target should trigger positive signal",
      "kpi_metric": "Total Sessions",
      "kpi_target": "100",
      "kpi_unit": "count",
      "expect_text": "exceeds target",
      "expect_severity": "low"
    },
    {
      "id": "financial_integrity",
      "description": "Insights should show Spend and Revenue in executive financials",
      "expect_text": "Spend",
      "expect_also": "Revenue"
    }
  ]
}
